# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local safety backups (generated by npm run safety:backup)
/backups/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Python (or-tools-service backend + general)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# or-tools-service specific (venv, local env, caches, logs)
or-tools-service/.venv/
or-tools-service/.env
or-tools-service/.env.local
or-tools-service/*.log
or-tools-service/**/__pycache__/
or-tools-service/*.pyc
or-tools-service/*.pyo

# typescript
*.tsbuildinfo
next-env.d.ts
