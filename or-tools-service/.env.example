# or-tools-service/.env.example
# Copy to .env and adjust for local/dev. Most values have safe defaults.

# Public OSRM (no key). Override only if self-hosting OSRM.
OSRM_BASE=https://router.project-osrm.org

# Request timeout for OSRM calls (seconds)
HTTP_TIMEOUT=15.0

# Solver tuning (advanced)
SOLVER_TIME_LIMIT_S=4
SOLVER_SOLUTION_LIMIT=32

# Extra CORS origins (comma separated, no spaces)
# EXTRA_CORS_ORIGINS=https://your-prod.example.com,https://another.example.com

# Port (uvicorn respects $PORT in many PaaS; default 8001 in code/README)
# PORT=8001

# When calling from Next.js, set on the Next side:
# ORTOOLS_SERVICE_URL=http://localhost:8001
