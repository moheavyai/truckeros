# =============================================================================
# TruckerOS — environment variables (Next.js app)
# =============================================================================
#
# Quick start:
#   1. Copy this file:  cp .env.local.example .env.local   (or copy/paste on Windows)
#   2. Fill in the REQUIRED Supabase values below
#   3. Restart the dev server:  npm run dev
#
# .env.local is gitignored and must never be committed.
# Find keys in Supabase Dashboard → Project Settings → API.
#
# Variable names in this project:
#   SUPABASE_URL          → NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_ANON_KEY     → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   (Next.js requires the NEXT_PUBLIC_ prefix for browser-exposed values.)
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase (REQUIRED)
# -----------------------------------------------------------------------------

# Project URL (SUPABASE_URL)
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public API key (SUPABASE_ANON_KEY) — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key (SUPABASE_SERVICE_ROLE_KEY) — SERVER ONLY, bypasses RLS
# Required for: GET/POST /api/admin/migrate, schema health checks, admin scripts
# NEVER commit this value or expose it to the client.
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database password for live migrations via POST /api/admin/migrate (server-only).
# Dashboard → Project Settings → Database → Database password
# Alternatively set a full DATABASE_URL connection string.
# SUPABASE_DB_PASSWORD=your-database-password
# DATABASE_URL=postgresql://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres

# Comma-separated admin emails allowed to call GET/POST /api/admin/migrate (server-only).
# Alternatively users with app_metadata.role === 'admin' are always allowed.
# ADMIN_EMAILS=you@example.com,teammate@example.com

# Comma-separated emails that always receive primary Owner / carrier-save break-glass treatment
# (lib/forced-carrier-owner.ts). Prefer NEXT_PUBLIC_ so client UI and server APIs share the list.
# Server-only FORCED_CARRIER_OWNER_EMAILS is also read when NEXT_PUBLIC_ is unset.
# Empty env: production → no forced owners; dev/test → temporary legacy hardcoded email fallback.
# Production deploys should set this explicitly (or leave empty to disable break-glass).
# NEXT_PUBLIC_FORCED_CARRIER_OWNER_EMAILS=you@example.com
# FORCED_CARRIER_OWNER_EMAILS=you@example.com

# DANGER: Allow live DDL via POST /api/admin/migrate in production (default: disabled).
# Without this flag, production POST returns 403 and you must run SQL manually in Supabase.
# When enabled, the server logs a prominent warning on each live apply.
# MIGRATE_ALLOW_LIVE_IN_PRODUCTION=true


# -----------------------------------------------------------------------------
# Routing — OR-Tools (optional for local dev)
# -----------------------------------------------------------------------------
# Python FastAPI service for multi-stop / corridor optimization.
# Start locally:  cd or-tools-service && uvicorn app.main:app --reload --port 8000
# Health check:   GET /api/ortools-health
ORTOOLS_SERVICE_URL=http://127.0.0.1:8000/optimize-route

# Upstream request timeout in milliseconds (default: 180000 = 3 minutes)
# ORTOOLS_TIMEOUT_MS=180000


# -----------------------------------------------------------------------------
# Routing — GraphHopper (optional)
# -----------------------------------------------------------------------------
# Enables truck-profile routing; without a key the app falls back to OSRM.
# Free tier: https://www.graphhopper.com/
GRAPHHOPPER_API_KEY=your-graphhopper-api-key


# -----------------------------------------------------------------------------
# Portal Assist — encrypted credentials (optional)
# -----------------------------------------------------------------------------
# 32-byte random key, base64-encoded (AES-256-GCM for stored portal logins).
# Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Also create a private Supabase Storage bucket named "portal-pdfs" with owner RLS.
# PORTAL_CREDENTIALS_ENCRYPTION_KEY=your-32-byte-base64-key-here


# -----------------------------------------------------------------------------
# Development / testing only (optional)
# -----------------------------------------------------------------------------
# Set to 1 to run live Nominatim integration tests (npm test — skipped by default)
# LIVE_GEOCODE=1


# -----------------------------------------------------------------------------
# OR-Tools Python service (separate process)
# -----------------------------------------------------------------------------
# The FastAPI solver has its own env file. See:
#   or-tools-service/.env.example
# Copy to or-tools-service/.env when self-hosting OSRM or tuning solver timeouts.